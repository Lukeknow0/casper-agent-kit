{
  "name": "casper-agent-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP-native toolkit for building autonomous Casper agents, with a Treasury Guard demo.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "dev:mcp": "tsx src/mcp/server.ts",
    "mcp:smoke": "tsx scripts/mcp-smoke-test.ts",
    "demo:agent": "tsx src/agent/treasury-guard.ts",
    "verify:proof": "tsx scripts/verify-proof.ts",
    "dashboard": "tsx src/dashboard/server.ts",
    "dashboard:vite": "vite --host 127.0.0.1 dashboard",
    "contract:build": "make -C contracts/treasury_guard build-contract",
    "contract:deploy": "tsx scripts/deploy-contract.ts",
    "keys:generate": "tsx scripts/generate-keys.ts",
    "keys:balance": "tsx scripts/check-balance.ts",
    "demo:transfer": "tsx scripts/send-transfer.ts",
    "ci": "npm run build && npm run check && npm run contract:build && npm run verify:proof && npm run mcp:smoke && npm run audit:high",
    "audit:high": "npm audit --audit-level=high --registry=https://registry.npmjs.org"
  },
  "keywords": [
    "casper-blockchain",
    "casper-network",
    "buildathon",
    "casper",
    "mcp",
    "ai-agent",
    "web3",
    "defi",
    "typescript",
    "rust",
    "agentic-ai",
    "treasury",
    "dorahacks"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "casper-js-sdk": "^5.0.12",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "playwright": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.3"
  },
  "homepage": "https://dorahacks.io/buidl/46036/"
}
