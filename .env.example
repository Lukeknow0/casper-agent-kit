# Public Casper node RPC endpoint used for read-only tools.
CASPER_RPC_URL=https://node.testnet.casper.network/rpc

# Explorer base for links printed by the demo.
CASPER_EXPLORER_BASE_URL=https://testnet.cspr.live

# Contract hash for the deployed Treasury Guard contract.
CASPER_TREASURY_CONTRACT_HASH=

# Default mode is dry-run. Set to false only after live signing is configured.
CASPER_DRY_RUN=true

# Optional live transaction command adapter. Leave unset for demo/dry-run mode.
CASPER_CLIENT_BIN=casper-client
CASPER_SECRET_KEY_PATH=

# CSPR.cloud REST API. Requires an access token from the CSPR.build console.
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_API_TOKEN=

# Optional OpenAI-compatible LLM endpoint for the Decide stage.
# Leave unset to use deterministic local reasoning.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
